# ===========================================
# Thumbnail Generator - Environment Variables
# ===========================================

# Application
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# App URL (for metadata and social sharing)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Next.js
NEXT_TELEMETRY_DISABLED=1

# Database (if using Prisma)
# DATABASE_URL="postgresql://user:password@localhost:5432/thumbnail_gen"

# API Keys (if needed for external services)
# OPENAI_API_KEY=sk-...
# YOUTUBE_API_KEY=AIza...

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Feature Flags
# ENABLE_PRO_FEATURES=true
