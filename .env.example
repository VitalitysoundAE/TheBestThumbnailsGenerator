# ===========================================
# Thumbnail Generator - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE (Optional - for user accounts)
# ===========================================
DATABASE_URL=file:./db/custom.db

# ===========================================
# AI IMAGE GENERATION PROVIDERS
# ===========================================
# At least one provider is required for image generation
# Multiple providers enable automatic fallback

# Cloudflare Workers AI (Free: 10,000 images/month)
# Get credentials: https://dash.cloudflare.com/
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# Hugging Face (Free: ~30 images/day)
# Get API key: https://huggingface.co/settings/tokens
HUGGING_FACE_API_KEY=your_api_key_here

# Stability AI (Free credits on signup)
# Get API key: https://platform.stability.ai/
STABILITY_API_KEY=your_api_key_here

# Replicate (Free credits on signup)
# Get API key: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=your_api_key_here

# ===========================================
# ADVERTISING (Optional - for monetization)
# ===========================================
# Enable/disable ads globally
NEXT_PUBLIC_ADS_ENABLED=false

# Ad network: adsense, media.net, or custom
NEXT_PUBLIC_AD_NETWORK=adsense

# Google AdSense
# Get your Publisher ID: https://www.google.com/adsense/
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_ADSENSE_SLOT_HEADER=1234567890
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=1234567891
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=1234567892
NEXT_PUBLIC_ADSENSE_SLOT_INLINE=1234567893

# ===========================================
# ANALYTICS (Optional)
# ===========================================
# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===========================================
# APP CONFIGURATION
# ===========================================
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=Thumbnail Generator

# ===========================================
# LEGAL (Required for GDPR compliance)
# ===========================================
# Your contact email for privacy inquiries
LEGAL_CONTACT_EMAIL=privacy@your-domain.com
